<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:tools="http://schemas.android.com/tools" android:layout_width="match_parent"
    android:layout_height="match_parent" android:fillViewport="true" android:background="@color/surface_soft"
    tools:context=".GeneratorFragment" tools:theme="@style/Theme.PassPulse">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:paddingStart="16dp" android:paddingTop="18dp"
        android:paddingEnd="16dp" android:paddingBottom="18dp">
        <com.google.android.material.card.MaterialCardView android:layout_width="match_parent"
            android:layout_height="wrap_content" app:cardBackgroundColor="@android:color/white"
            app:cardCornerRadius="24dp" app:cardElevation="2dp" app:strokeColor="#E8EDF3" app:strokeWidth="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:gravity="center_vertical" android:padding="20dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="Generador de&#10;Contraseñas Seguro" android:textColor="@color/text_primary"
                    android:textSize="25sp" android:textStyle="bold" />
                <ImageView android:layout_width="64dp" android:layout_height="64dp"
                    android:src="@drawable/passpulse_logo" android:contentDescription="@string/app_name"
                    android:scaleType="centerInside" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        <com.google.android.material.card.MaterialCardView android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginTop="14dp"
            app:cardBackgroundColor="@android:color/white" app:cardCornerRadius="22dp" app:cardElevation="2dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:gravity="center_vertical" android:padding="14dp">
                <TextView android:id="@+id/passwordText" android:layout_width="0dp" android:layout_height="58dp"
                    android:layout_weight="1" android:background="@drawable/bg_password" android:gravity="center_vertical"
                    android:maxLines="1" android:paddingStart="14dp" android:paddingEnd="8dp" tools:text="f7#G9vK%p2Q1!bT"
                    android:textColor="@color/text_primary" android:textSize="21sp" />
                <LinearLayout android:id="@+id/copyContainer" android:layout_width="62dp" android:layout_height="wrap_content" android:gravity="center"
                    android:orientation="vertical" android:clickable="true" android:focusable="true">
                    <ImageView android:layout_width="30dp" android:layout_height="30dp" android:src="@drawable/ic_copy"
                        android:contentDescription="@string/copy" />
                    <TextView android:id="@+id/copyButton" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Copiar" android:textColor="@color/text_primary" android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="14dp" app:cardBackgroundColor="@android:color/white" app:cardCornerRadius="22dp" app:cardElevation="2dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="18dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Longitud" android:textColor="@color/text_primary" android:textSize="17sp" />
                    <TextView android:id="@+id/lengthValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:background="@drawable/bg_length_badge" android:paddingStart="12dp" android:paddingEnd="12dp" android:paddingTop="6dp" android:paddingBottom="6dp" android:textColor="@color/primary_blue" android:textSize="14sp" android:textStyle="bold" />
                </LinearLayout>
                <com.google.android.material.slider.Slider android:id="@+id/lengthSlider" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="5dp" android:valueFrom="8" android:valueTo="32" android:stepSize="1" android:value="16" app:thumbColor="@color/primary_blue" app:trackColorActive="@color/primary_blue" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="14dp" app:cardBackgroundColor="@android:color/white" app:cardCornerRadius="22dp" app:cardElevation="2dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingTop="12dp" android:paddingBottom="12dp">
                <LinearLayout android:id="@+id/uppercaseOption" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="A" android:textColor="@color/primary_blue" android:textSize="26sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mayúsculas" android:textColor="@color/text_primary" android:textSize="14sp" />
                    <com.google.android.material.materialswitch.MaterialSwitch android:id="@+id/uppercaseSwitch" android:layout_width="wrap_content" android:layout_height="wrap_content" android:checked="true" />
                </LinearLayout>
                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#DDE3EA" />
                <LinearLayout android:id="@+id/numbersOption" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1" android:textColor="#78838D" android:textSize="26sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Números" android:textColor="@color/text_primary" android:textSize="14sp" />
                    <com.google.android.material.materialswitch.MaterialSwitch android:id="@+id/numbersSwitch" android:layout_width="wrap_content" android:layout_height="wrap_content" android:checked="false" />
                </LinearLayout>
                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#DDE3EA" />
                <LinearLayout android:id="@+id/symbolsOption" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="#" android:textColor="@color/primary_blue" android:textSize="26sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Símbolos" android:textColor="@color/text_primary" android:textSize="14sp" />
                    <com.google.android.material.materialswitch.MaterialSwitch android:id="@+id/symbolsSwitch" android:layout_width="wrap_content" android:layout_height="wrap_content" android:checked="true" />
                </LinearLayout>
                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#DDE3EA" />
                <LinearLayout android:id="@+id/lowercaseOption" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="a" android:textColor="@color/primary_blue" android:textSize="26sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Minúsculas" android:textColor="@color/text_primary" android:textSize="14sp" />
                    <com.google.android.material.materialswitch.MaterialSwitch android:id="@+id/lowercaseSwitch" android:layout_width="wrap_content" android:layout_height="wrap_content" android:checked="true" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" app:cardBackgroundColor="@android:color/white" app:cardCornerRadius="18dp" app:cardElevation="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="14dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cantidad de caracteres por requisito" android:textColor="@color/text_primary" android:textSize="15sp" android:textStyle="bold" />
                <LinearLayout android:id="@+id/lowercaseCountPanel" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone">
                    <TextView android:id="@+id/lowercaseCountValue" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/text_secondary" android:textSize="13sp" />
                    <com.google.android.material.slider.Slider android:id="@+id/lowercaseCountSlider" android:layout_width="match_parent" android:layout_height="wrap_content" android:valueFrom="1" android:valueTo="16" android:stepSize="1" android:value="2" />
                </LinearLayout>
                <LinearLayout android:id="@+id/uppercaseCountPanel" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone">
                    <TextView android:id="@+id/uppercaseCountValue" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/text_secondary" android:textSize="13sp" />
                    <com.google.android.material.slider.Slider android:id="@+id/uppercaseCountSlider" android:layout_width="match_parent" android:layout_height="wrap_content" android:valueFrom="1" android:valueTo="16" android:stepSize="1" android:value="2" />
                </LinearLayout>
                <LinearLayout android:id="@+id/numbersCountPanel" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone">
                    <TextView android:id="@+id/numbersCountValue" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/text_secondary" android:textSize="13sp" />
                    <com.google.android.material.slider.Slider android:id="@+id/numbersCountSlider" android:layout_width="match_parent" android:layout_height="wrap_content" android:valueFrom="1" android:valueTo="16" android:stepSize="1" android:value="1" />
                </LinearLayout>
                <LinearLayout android:id="@+id/symbolsCountPanel" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone">
                    <TextView android:id="@+id/symbolsCountValue" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/text_secondary" android:textSize="13sp" />
                    <com.google.android.material.slider.Slider android:id="@+id/symbolsCountSlider" android:layout_width="match_parent" android:layout_height="wrap_content" android:valueFrom="1" android:valueTo="16" android:stepSize="1" android:value="2" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        <com.google.android.material.button.MaterialButton android:id="@+id/generateButton" android:layout_width="match_parent" android:layout_height="58dp" android:layout_marginTop="16dp" android:text="↻  Generar Nueva Contraseña" android:textSize="16sp" app:backgroundTint="@color/primary_blue" app:cornerRadius="18dp" />
        <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" app:cardBackgroundColor="@android:color/white" app:cardCornerRadius="22dp" app:cardElevation="2dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="18dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"><TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Contraseñas Guardadas" android:textColor="@color/text_primary" android:textSize="18sp" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Historial" android:textColor="@color/text_primary" android:textSize="16sp" /></LinearLayout>
                <TextView android:id="@+id/historyEmpty" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:padding="18dp" android:text="Aún no hay contraseñas guardadas" android:textColor="@color/text_secondary" android:visibility="gone" />
                <androidx.recyclerview.widget.RecyclerView android:id="@+id/historyList" android:layout_width="match_parent" android:layout_height="wrap_content" android:nestedScrollingEnabled="false" android:layout_marginTop="8dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
